{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "axiom-landing",
	"compatibility_date": "2026-02-28",
	"compatibility_flags": ["nodejs_compat"],
	"main": "./workers/app.ts",
	"observability": { "enabled": true },
	"ai": { "binding": "AI" },
	"vars": { "AI_VIRTUAL_MODEL": "auto" },
	"assets": { "directory": "./public/", "binding": "ASSETS" }
}
